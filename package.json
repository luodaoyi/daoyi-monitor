{
  "name": "daoyi-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "d1:migrate:local": "wrangler d1 migrations apply DB --local",
    "build:web": "npm --prefix web install --package-lock=false && npm --prefix web run build",
    "build": "npm run build:web && npm run typecheck",
    "deploy": "node scripts/deploy-cloudflare.mjs"
  },
  "dependencies": {
    "hono": "^4.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250906.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.0"
  }
}
